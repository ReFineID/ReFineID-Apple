<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<!-- iOS host entitlements. iOS apps are always sandboxed.
	 The com.apple.token is the CTK token keychain group the host reads published identities through. -->
<dict>
	<key>keychain-access-groups</key>
	<array>
		<string>$(AppIdentifierPrefix)fi.refineid.ReFineID</string>
		<string>com.apple.token</string>
	</array>
</dict>
</plist>
